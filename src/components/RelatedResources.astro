---
import { getCollection } from 'astro:content';
const { ids } = Astro.props;
const resources = await getCollection('resources');
const title = (id) => resources.find((r) => r.data.id === id)?.data.title ?? id;
---
{ids?.length > 0 && (
  <div style="border:1px solid var(--line);border-radius:8px;overflow:hidden">
    {ids.map((id) => (
      <a href={`/RFSAM/resources#${id.toLowerCase()}`} style="display:flex;gap:14px;padding:12px 16px;background:var(--bg2);border-bottom:1px solid var(--line)">
        <span class="mono" style="font-size:11.5px;color:var(--cyan);width:124px;flex-shrink:0">{id}</span>
        <span style="font-size:13.5px">{title(id)}</span>
      </a>
    ))}
  </div>
)}
