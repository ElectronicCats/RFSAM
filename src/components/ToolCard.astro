---
// Renders one tool. `tool` is the tool entry's data; role/why/caveat are the
// optional toolchain-context fields explaining its use at a given step.
// `software` (array of tool data) renders nested under hardware as "runs:".
const { tool, role, why, caveat, needs, software = [], compact = false } = Astro.props;
const typeColor = { hardware: 'var(--cyan)', software: 'var(--green)', project: 'var(--purple)' }[tool.type] ?? 'var(--mut)';
const link = tool.repo ?? tool.homepage;
const linkLabel = tool.repo ? 'repo ↗' : (tool.homepage ? 'site ↗' : null);
const slugify = (n) => n.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
---
<div style="border:1px solid var(--line);border-radius:8px;padding:14px 16px;background:var(--panel);height:100%;box-sizing:border-box">
  <div style="display:flex;align-items:baseline;gap:10px;flex-wrap:wrap">
    <a href={`/RFSAM/tools/${tool.slug ?? slugify(tool.name)}`} style="font-family:var(--disp);font-weight:600;font-size:15px">{tool.name}</a>
    <span class="mono" style={`font-size:9px;letter-spacing:.08em;color:${typeColor};border:1px solid ${typeColor};border-radius:3px;padding:1px 5px`}>{tool.type.toUpperCase()}</span>
    <span class="mono" style="font-size:10px;color:var(--mut2)">{tool.vendor}</span>
    {link && <a href={link} target="_blank" rel="noopener" class="mono" style="font-size:10.5px;color:var(--amber);margin-left:auto">{linkLabel}</a>}
  </div>
  {tool.spec && <div class="mono" style="font-size:10.5px;color:var(--cyan);margin-top:6px">{tool.spec}</div>}
  {role && <div class="mono" style="font-size:11px;color:var(--orange);margin-top:8px;letter-spacing:.03em">{role}</div>}
  {why && <p style="font-size:13px;color:#CFD9E4;margin-top:4px;line-height:1.55">{why}</p>}
  {caveat && <p style="font-size:12px;color:var(--mut);margin-top:4px;line-height:1.5"><span style="color:var(--amber)">⚠ </span>{caveat}</p>}
  {needs && <p class="mono" style="font-size:11px;color:var(--cyan);margin-top:6px;line-height:1.5"><span style="color:var(--mut2)">NEEDS: </span>{needs}</p>}
  {!role && !why && !compact && <p style="font-size:12.5px;color:var(--mut);margin-top:8px;line-height:1.5;display:-webkit-box;-webkit-line-clamp:6;-webkit-box-orient:vertical;overflow:hidden">{tool.note}</p>}
  {software.length > 0 && (
    <div style="margin-top:10px;padding-top:10px;border-top:1px solid var(--line);display:flex;flex-wrap:wrap;gap:6px;align-items:center">
      <span class="mono" style="font-size:10px;color:var(--mut2);letter-spacing:.06em">RUNS:</span>
      {software.map((s) => (
        <span style="display:inline-flex;align-items:center;gap:5px;border:1px solid var(--line2);border-radius:4px;padding:2px 7px">
          <a href={`/RFSAM/tools/${s.slug ?? slugify(s.name)}`} class="mono" style="font-size:11px;color:var(--green)">{s.name}</a>
          {(s.repo || s.homepage) && <a href={s.repo ?? s.homepage} target="_blank" rel="noopener" style="font-size:10px;color:var(--amber)">↗</a>}
        </span>
      ))}
    </div>
  )}
</div>
