---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { protocols } from '../../data/protocols.js';
import { toolchains } from '../../data/toolchains.js';

const nodes = [{ id: 'rfsam', name: 'RFSAM', kind: 'root' }];
const links = [];
for (const p of protocols) {
  nodes.push({ id: p.id, name: p.name, kind: 'protocol', complete: (toolchains[p.id]?.status ?? 'planned') === 'complete', href: `/wayfinder/${p.id.toLowerCase()}` });
  links.push({ source: 'rfsam', target: p.id });
}
const graphJson = JSON.stringify({ nodes, links });
---
<BaseLayout title="Wayfinder">
  <div id="wf-wrap">
    <div id="wf-graph"></div>
    <div id="wf-hint" class="mono">RF Wayfinder · pick a technology to see its assessment path and the kit you need · drag · scroll to zoom</div>
    <div id="wf-legend" class="mono">
      <span><i style="background:#FF7A1A"></i>toolchain ready</span>
      <span><i style="background:#2FB8E0"></i>planned</span>
    </div>
  </div>

  <script type="application/json" id="wf-data" set:html={graphJson}></script>
  <script>
    import ForceGraph from 'force-graph';
    import { forceCollide } from 'd3-force';

    const data = JSON.parse(document.getElementById('wf-data').textContent);
    const colorFor = (n) => n.kind === 'root' ? '#FF7A1A' : (n.complete ? '#FF7A1A' : '#2FB8E0');
    const radiusFor = (n) => n.kind === 'root' ? 9 : 6;

    const el = document.getElementById('wf-graph');
    const graph = new ForceGraph(el)
      .backgroundColor('#0A1119')
      .graphData(data)
      .linkColor(() => 'rgba(136,154,171,0.25)')
      .linkWidth(() => 0.6)
      .linkDirectionalParticles(1)
      .linkDirectionalParticleWidth(1.6)
      .linkDirectionalParticleColor(() => 'rgba(47,184,224,0.7)')
      .nodeCanvasObject((node, ctx, scale) => {
        const r = radiusFor(node);
        ctx.globalAlpha = node.kind === 'protocol' && !node.complete ? 0.6 : 1;
        ctx.beginPath(); ctx.arc(node.x, node.y, r, 0, 2 * Math.PI);
        ctx.fillStyle = colorFor(node); ctx.fill();
        ctx.globalAlpha = 1;
        const fontSize = Math.max(4, 11 / scale);
        ctx.font = `${fontSize}px Inter, system-ui, sans-serif`;
        ctx.textAlign = 'center'; ctx.textBaseline = 'top';
        ctx.lineWidth = 3 / scale; ctx.strokeStyle = 'rgba(10,17,25,0.92)';
        ctx.strokeText(node.name, node.x, node.y + r + 2 / scale);
        ctx.fillStyle = '#D7E0EA';
        ctx.fillText(node.name, node.x, node.y + r + 2 / scale);
      })
      .nodePointerAreaPaint((node, color, ctx) => {
        ctx.beginPath(); ctx.arc(node.x, node.y, radiusFor(node) + 3, 0, 2 * Math.PI); ctx.fillStyle = color; ctx.fill();
      })
      .onNodeClick((node) => { if (node.href) window.location.href = import.meta.env.BASE_URL.replace(/\/$/, '') + node.href; });

    graph.d3Force('charge').strength(-280);
    graph.d3Force('link').distance(150);
    graph.d3Force('collide', forceCollide((n) => radiusFor(n) + 16));
    function size() { graph.width(el.clientWidth).height(el.clientHeight); }
    size();
    window.addEventListener('resize', size);
    setTimeout(() => graph.zoomToFit(600, 100), 700);
  </script>

  <style>
    #wf-wrap { position: relative; height: calc(100vh - 53px); overflow: hidden; }
    #wf-graph { position: absolute; inset: 0; }
    #wf-hint { position: absolute; top: 14px; left: 16px; font-size: 11px; color: var(--mut2); pointer-events: none; }
    #wf-legend { position: absolute; bottom: 14px; left: 16px; display: flex; gap: 14px; font-size: 11px; color: var(--mut); }
    #wf-legend i { display: inline-block; width: 9px; height: 9px; border-radius: 50%; margin-right: 5px; vertical-align: middle; }
    :global(body:has(#wf-wrap)) footer { display: none; }
  </style>
</BaseLayout>
